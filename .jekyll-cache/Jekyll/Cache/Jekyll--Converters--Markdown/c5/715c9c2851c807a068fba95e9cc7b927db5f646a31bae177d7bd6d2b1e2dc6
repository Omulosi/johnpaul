    <span class="n">DEFAULT_USER_LOGINS</span> <span class="o">=</span> <span class="p">{</span><span class="s">'email'</span><span class="p">:</span><span class="s">'user@example.com'</span><span class="p">,</span> <span class="s">'password'</span><span class="p">:</span><span class="s">'r@78hy'</span><span class="p">}</span>

